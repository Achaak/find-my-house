generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ListingSource {
  bienici
  seloger
  leboncoin
  logicimmo
}

enum ReactionType {
  like
  dislike
}

model Property {
  id            Int       @id @default(autoincrement())
  propertyKey   String    @unique @map("property_key")
  title         String
  price         Int
  firstPrice    Int       @map("first_price")
  surface       Float?
  landSurface   Float?    @map("land_surface")
  rooms         Int?
  bedrooms      Int?
  isNewProperty Boolean?  @map("is_new_property")
  latitude      Float?
  longitude     Float?
  city          String
  postalCode    String?   @map("postal_code")
  address       String?
  dpeNumero     String?   @map("dpe_numero")
  description   String?
  imageUrl      String?   @map("image_url")
  propertyType  String?   @map("property_type")
  dpeClass             String? @map("dpe_class")
  gesClass             String? @map("ges_class")
  dpeConsumptionKwhM2  Float?  @map("dpe_consumption_kwh_m2")
  gesEmissionKgM2      Float?  @map("ges_emission_kg_m2")
  bathrooms            Int?
  constructionYear     Int?     @map("construction_year")
  heating              String?
  orientation          String?
  propertyCondition    String?  @map("property_condition")
  parkingSpaces        Int?     @map("parking_spaces")
  highlights           Json?
  displayEnrichedAt    DateTime? @map("display_enriched_at")
  addressEnrichedAt    DateTime? @map("address_enriched_at")
  firstSeenAt   DateTime  @map("first_seen_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  publications ListingPublication[]
  reactions    ListingReaction[]

  @@index([city])
  @@index([price])
  @@index([firstSeenAt])
  @@map("properties")
}

model ListingPublication {
  id         Int      @id @default(autoincrement())
  propertyId Int      @map("property_id")
  externalId String   @map("external_id")
  source     ListingSource
  url        String        @unique
  agencySlug String?  @map("agency_slug")
  agencyRef  String?  @map("agency_ref")
  isActive   Boolean  @default(true) @map("is_active")
  scrapedAt  DateTime @map("scraped_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([propertyId])
  @@index([source, isActive])
  @@index([agencySlug, agencyRef])
  @@map("listing_publications")
}

model ListingReaction {
  id         Int          @id @default(autoincrement())
  propertyId Int          @unique @map("property_id")
  type       ReactionType
  archivedAt DateTime?    @map("archived_at")
  createdAt  DateTime     @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([type])
  @@map("listing_reactions")
}
