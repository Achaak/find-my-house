generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ListingSource {
  bienici
  seloger
  leboncoin
  logicimmo
}

enum ReactionType {
  like
  dislike
}

model Property {
  id            Int       @id @default(autoincrement())
  propertyKey   String    @unique @map("property_key")
  title         String
  price         Int
  firstPrice    Int       @map("first_price")
  hasPriceDrop  Boolean   @default(false) @map("has_price_drop")
  surface       Float?
  landSurface   Float?    @map("land_surface")
  rooms         Int?
  bedrooms      Int?
  isNewProperty Boolean?  @map("is_new_property")
  latitude      Float?
  longitude     Float?
  city          String
  postalCode    String?   @map("postal_code")
  dpeClass             String? @map("dpe_class")
  gesClass             String? @map("ges_class")
  addressEnrichedAt    DateTime? @map("address_enriched_at")
  firstSeenAt   DateTime  @map("first_seen_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  publications ListingPublication[]
  reactions    ListingReaction[]

  @@index([city])
  @@index([price])
  @@index([firstSeenAt])
  @@index([hasPriceDrop, price])
  @@map("properties")
}

model ListingPublication {
  id         Int      @id @default(autoincrement())
  propertyId Int      @map("property_id")
  externalId String   @map("external_id")
  source     ListingSource
  url        String        @unique
  title      String
  price      Int
  surface       Float?
  landSurface   Float?    @map("land_surface")
  rooms         Int?
  bedrooms      Int?
  isNewProperty Boolean?  @map("is_new_property")
  latitude      Float?
  longitude     Float?
  city          String
  postalCode    String?   @map("postal_code")
  address       String?
  dpeNumero     String?   @map("dpe_numero")
  description   String?
  imageUrl      String?   @map("image_url")
  imageUrls     Json?     @map("image_urls")
  imageLocalHashes Json?  @map("image_local_hashes")
  imagePerceptualHashes Json? @map("image_perceptual_hashes")
  enrichedAt         DateTime? @map("enriched_at")
  propertyType  String?   @map("property_type")
  dpeClass             String? @map("dpe_class")
  gesClass             String? @map("ges_class")
  dpeConsumptionKwhM2  Float?  @map("dpe_consumption_kwh_m2")
  gesEmissionKgM2      Float?  @map("ges_emission_kg_m2")
  bathrooms            Int?
  constructionYear     Int?     @map("construction_year")
  heating              String?
  orientation          String?
  propertyCondition    String?  @map("property_condition")
  parkingSpaces        Int?     @map("parking_spaces")
  highlights           Json?
  agencySlug String?  @map("agency_slug")
  agencyRef  String?  @map("agency_ref")
  isActive   Boolean  @default(true) @map("is_active")
  scrapedAt  DateTime @map("scraped_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([propertyId])
  @@index([propertyId, isActive, scrapedAt])
  @@index([source, isActive])
  @@index([isActive, city, postalCode])
  @@index([isActive, price])
  @@index([isActive, surface])
  @@index([isActive, enrichedAt])
  @@index([agencySlug, agencyRef])
  @@map("listing_publications")
}

model ListingReaction {
  id         Int          @id @default(autoincrement())
  propertyId Int          @unique @map("property_id")
  type       ReactionType
  archivedAt DateTime?    @map("archived_at")
  createdAt  DateTime     @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([type])
  @@map("listing_reactions")
}

model PropertyMatchDiagnostic {
  id                Int           @id @default(autoincrement())
  listingSource     ListingSource @map("listing_source")
  listingExternalId String        @map("listing_external_id")
  postalCode        String?       @map("postal_code")
  threshold         Float
  bestScore         Float?        @map("best_score")
  bestCandidateId   Int?          @map("best_candidate_id")
  bestVeto          String?       @map("best_veto")
  nearMisses        Json          @map("near_misses")
  createdAt         DateTime      @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([listingSource, listingExternalId])
  @@map("property_match_diagnostics")
}

model UserNotificationPreference {
  userId    String   @id @map("user_id")
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_notification_preferences")
}

model StatsDailySnapshot {
  date               String @id
  activeProperties   Int    @map("active_properties")
  activePublications Int    @map("active_publications")
  medianPrice        Int    @map("median_price")
  priceDropCount     Int    @map("price_drop_count")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("stats_daily_snapshots")
}
