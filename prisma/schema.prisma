generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Listing {
  id           Int      @id @default(autoincrement())
  externalId   String   @map("external_id")
  source       String
  title        String
  price        Int
  surface      Float?
  landSurface  Float?   @map("land_surface")
  rooms        Int?
  bedrooms     Int?
  isNewProperty Boolean? @map("is_new_property")
  latitude     Float?
  longitude    Float?
  city         String
  postalCode   String?  @map("postal_code")
  url          String   @unique
  description  String?
  imageUrl     String?  @map("image_url")
  propertyType String?  @map("property_type")
  scrapedAt    DateTime @map("scraped_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  reactions ListingReaction[]

  @@unique([source, externalId])
  @@index([city])
  @@index([price])
  @@index([scrapedAt])
  @@map("listings")
}

model ListingReaction {
  id            Int      @id @default(autoincrement())
  discordUserId String   @map("discord_user_id")
  listingId     Int      @map("listing_id")
  type          String
  createdAt     DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([discordUserId, listingId])
  @@index([discordUserId, type])
  @@map("listing_reactions")
}
