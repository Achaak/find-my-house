generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ListingSource {
  bienici
  seloger
  leboncoin
}

enum ReactionType {
  like
  dislike
}

model Property {
  id            Int       @id @default(autoincrement())
  propertyKey   String    @unique @map("property_key")
  title         String
  price         Int
  firstPrice    Int       @map("first_price")
  surface       Float?
  landSurface   Float?    @map("land_surface")
  rooms         Int?
  bedrooms      Int?
  isNewProperty Boolean?  @map("is_new_property")
  latitude      Float?
  longitude     Float?
  city          String
  postalCode    String?   @map("postal_code")
  address       String?
  dpeNumero     String?   @map("dpe_numero")
  description   String?
  imageUrl      String?   @map("image_url")
  propertyType  String?   @map("property_type")
  dpeClass             String? @map("dpe_class")
  gesClass             String? @map("ges_class")
  dpeConsumptionKwhM2  Float?  @map("dpe_consumption_kwh_m2")
  gesEmissionKgM2      Float?  @map("ges_emission_kg_m2")
  firstSeenAt   DateTime  @map("first_seen_at")
  notifiedAt    DateTime? @map("notified_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  publications ListingPublication[]
  reactions    ListingReaction[]

  @@index([city])
  @@index([price])
  @@index([firstSeenAt])
  @@map("properties")
}

model ListingPublication {
  id         Int      @id @default(autoincrement())
  propertyId Int      @map("property_id")
  externalId String   @map("external_id")
  source     ListingSource
  url        String        @unique
  scrapedAt  DateTime @map("scraped_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([propertyId])
  @@map("listing_publications")
}

model ListingReaction {
  id            Int      @id @default(autoincrement())
  discordUserId String   @map("discord_user_id")
  propertyId    Int      @map("property_id")
  type          ReactionType
  createdAt     DateTime     @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([discordUserId, propertyId])
  @@index([discordUserId, type])
  @@map("listing_reactions")
}
