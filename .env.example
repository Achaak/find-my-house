# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_GUILD_ID=your_guild_id_for_dev_commands
DISCORD_CHANNEL_ID=your_discord_channel_id
# Role allowed to run /scraper (guild owner is always allowed)
DISCORD_ADMIN_ROLE_ID=your_admin_role_id

# Scraping
# Active scrapers (comma-separated). If omitted, all are enabled.
# Allowed values: bienici, leboncoin, seloger, logicimmo
SCRAPE_SCRAPERS=bienici,leboncoin,seloger,logicimmo
SCRAPE_CRON=0 */2 * * *
SCRAPE_CITY=Paris
SCRAPE_MAX_PRICE=500000
SCRAPE_MIN_SURFACE=30
SCRAPE_MIN_LAND_SURFACE=1000
SCRAPE_MIN_ROOMS=4
SCRAPE_MIN_BEDROOMS=3
SCRAPE_ANCIEN_ONLY=true
# Max driving time from SCRAPE_CITY (takes priority over SCRAPE_RADIUS_KM)
SCRAPE_MAX_TRAVEL_MINUTES=40
SCRAPE_RADIUS_KM=20
# Max result pages fetched per portal per scrape run
SCRAPE_MAX_PAGES=20

# Database (Prisma)
# DATABASE_URL takes priority; otherwise DATABASE_PATH is used (default ./data/listings.db)
DATABASE_URL="file:./data/listings.db"
# DATABASE_PATH=./data/listings.db

# Leboncoin API (optional — default is the public mobile app key)
# LEBONCOIN_API_KEY=ba0c2dad52b3ec

# Logging: debug | info | warn | error
LOG_LEVEL=info
