{
  "name": "find-my-house",
  "version": "3.1.2",
  "private": true,
  "description": "French real-estate listing scraper with Discord bot and web UI",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "turbo run dev",
    "dev:api": "tsx watch src/index.ts",
    "dev:web": "turbo run dev --filter=web",
    "build": "prisma generate && tsc",
    "build:all": "turbo run build",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "turbo run typecheck",
    "start": "node dist/index.js",
    "scrape": "tsx src/scripts/scrape-once.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reconcile": "tsx src/scripts/reconcile-properties.ts",
    "postinstall": "prisma generate && pnpm --filter @find-my-house/api-types build",
    "lint": "eslint .",
    "lint:all": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:all": "turbo run test",
    "test:watch": "vitest",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "prepare": "husky"
  },
  "keywords": [
    "immobilier",
    "scraper",
    "discord",
    "sqlite"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@find-my-house/api-types": "workspace:*",
    "@discordjs/rest": "^2.6.1",
    "@hono/node-server": "^2.0.4",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.10.0",
    "cloakbrowser": "^0.3.31",
    "discord-api-types": "^0.38.48",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "got": "^15.0.5",
    "hono": "^4.12.25",
    "node-cron": "^4.2.1",
    "playwright-core": "^1.60.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@release-it/bumper": "^7.0.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "release-it": "^20.2.0",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  },
  "packageManager": "pnpm@9.15.3+sha256.c1da43727ccbc1ed42aff4fd6bdb4b1e91e65a818e6efff5b240fbf070ba4eaf"
}
