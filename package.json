{
  "name": "find-my-house",
  "version": "4.2.0",
  "private": true,
  "description": "French real-estate listing scraper with web UI",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "turbo run dev",
    "dev:api": "tsx watch src/index.ts",
    "dev:web": "turbo run dev --filter=web",
    "build": "prisma generate && tsc && node --input-type=module -e \"import { cpSync } from 'node:fs'; cpSync('src/data','dist/data',{ recursive: true });\"",
    "build:all": "turbo run build",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "turbo run typecheck",
    "start": "node dist/index.js",
    "scrape": "tsx src/scripts/scrape-once.ts",
    "db:generate": "prisma generate",
    "db:migrate": "tsx src/scripts/migrate-with-backup.ts",
    "db:migrate:deploy": "tsx src/scripts/migrate-with-backup.ts deploy",
    "db:push": "prisma db push",
    "db:reconcile": "tsx src/scripts/reconcile-properties.ts",
    "db:backfill:publication-centric": "tsx src/scripts/backfill-publication-centric.ts",
    "geo:build-postal-codes": "tsx src/scripts/build-postal-codes.ts",
    "postinstall": "prisma generate && pnpm --filter @find-my-house/api-types build",
    "lint": "eslint .",
    "lint:all": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:all": "turbo run test",
    "test:watch": "vitest",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "prepare": "husky"
  },
  "keywords": [
    "immobilier",
    "scraper",
    "sqlite"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@find-my-house/api-types": "workspace:*",
    "@hono/node-server": "^2.0.6",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "cloakbrowser": "^0.4.3",
    "dotenv": "^17.4.2",
    "got": "^15.0.6",
    "hono": "^4.12.27",
    "imghash": "^1.1.4",
    "node-cron": "^4.5.0",
    "playwright-core": "^1.61.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@release-it/bumper": "^7.0.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "@types/node-cron": "^3.0.11",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "prettier": "^3.9.0",
    "prisma": "^7.8.0",
    "release-it": "^20.2.1",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "packageManager": "pnpm@9.15.3+sha256.c1da43727ccbc1ed42aff4fd6bdb4b1e91e65a818e6efff5b240fbf070ba4eaf"
}
