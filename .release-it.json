{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "requireBranch": "main"
  },
  "github": {
    "release": true
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/bumper": {
      "out": {
        "file": "home-assistant/config.yaml",
        "type": "text/plain"
      }
    }
  },
  "hooks": {
    "before:init": ["pnpm lint", "pnpm format:check"]
  }
}
