# Shared defaults (versioned). Secrets and personal overrides → .env.local

# Scraping
# Allowed values: bienici, leboncoin, seloger, logicimmo
SCRAPE_SCRAPERS=bienici,leboncoin,seloger,logicimmo
SCRAPE_CRON=0 */2 * * *
SCRAPE_CITY=Paris
SCRAPE_MAX_PRICE=500000
SCRAPE_MIN_SURFACE=30
SCRAPE_MAX_PAGES=20

# Database (Prisma)
DATABASE_URL="file:./data/listings.db"

# CloakBrowser (LeBonCoin, SeLoger, Logic-Immo)
# CLOAKBROWSER_HEADLESS=false
# CLOAKBROWSER_PROFILE_DIR=./data/cloakbrowser-profile
# CLOAKBROWSER_HUMANIZE=true
# CLOAKBROWSER_FINGERPRINT=12345
# CLOAKBROWSER_STORAGE_QUOTA=5000
# CLOAKBROWSER_PROXY=http://user:pass@residential-proxy:port
# CLOAKBROWSER_GEOIP=true

# Logging: debug | info | warn | error
LOG_LEVEL=info
