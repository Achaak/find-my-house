# Copier vers .env.local et remplir (fichier ignoré par git)
# cp .env.local.example .env.local

# Discord (requis)
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_GUILD_ID=your_guild_id_for_dev_commands
DISCORD_CHANNEL_ID=your_discord_channel_id
DISCORD_ADMIN_ROLE_ID=your_admin_role_id

# Overrides scraping (optionnel — sinon valeurs de .env)
# SCRAPE_SCRAPERS=leboncoin
# SCRAPE_CITY=Paris
# SCRAPE_POSTAL_CODE=75001
# SCRAPE_MAX_PRICE=500000
# SCRAPE_MIN_SURFACE=30
# SCRAPE_MIN_LAND_SURFACE=1000
# SCRAPE_MIN_ROOMS=4
# SCRAPE_MIN_BEDROOMS=3
# SCRAPE_ANCIEN_ONLY=true
# SCRAPE_MAX_TRAVEL_MINUTES=45
# SeLoger/Logic-Immo : durées autorisées 5, 10, 15, 20, 25, 30, 45, 60 (valeur la plus proche sinon)
# SCRAPE_MAX_PAGES=20
# LOG_LEVEL=debug

# CloakBrowser (optionnel — voir https://github.com/CloakHQ/CloakBrowser)
# Laisser headless=true pour le scraping (recommandé). Headed=false ouvre une fenêtre
# Chromium et verrouille le profil entre deux runs.
# CLOAKBROWSER_HEADLESS=true
# CLOAKBROWSER_RESET_PROFILE=true
# CLOAKBROWSER_PROFILE_DIR=./data/cloakbrowser-profile
# CLOAKBROWSER_HUMANIZE=true
# CLOAKBROWSER_FINGERPRINT=12345
# CLOAKBROWSER_STORAGE_QUOTA=5000
# CLOAKBROWSER_PROXY=http://user:pass@residential-proxy:port
# CLOAKBROWSER_GEOIP=true
