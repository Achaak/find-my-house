# Copier vers .env.local et remplir (fichier ignoré par git)
# cp .env.local.example .env.local

# Overrides scraping (optionnel — sinon valeurs de .env)
# SCRAPE_SCRAPERS=leboncoin
# SCRAPE_CITY=Paris
# SCRAPE_POSTAL_CODE=75001
# SCRAPE_MAX_PRICE=500000
# SCRAPE_MIN_SURFACE=30
# SCRAPE_MIN_LAND_SURFACE=1000
# SCRAPE_MIN_ROOMS=4
# SCRAPE_MIN_BEDROOMS=3
# SCRAPE_ANCIEN_ONLY=true
# SCRAPE_MAX_TRAVEL_MINUTES=40
# SeLoger/Logic-Immo : valeurs intermédiaires → isochrone au palier supérieur,
# puis filtre via coords (fiche ou centroïde CP embarqué). Paliers : 5…60.
# Régénérer l'index CP : pnpm geo:build-postal-codes
# SCRAPE_MAX_PAGES=20
# LOG_LEVEL=debug

# Enrichissement automatique progressif (cron)
# ENRICHMENT_CRON=0 * * * *
# ENRICHMENT_DISABLED=true
# ENRICHMENT_MIN_COMPAT_SCORE=0
# ENRICHMENT_BATCH_LIMIT=20
# ENRICHMENT_SEARCH_LIMIT=1000

# Dev local du frontend (web/) — voir web/.env.example pour VITE_HA_TOKEN
# WEB_AUTH_DISABLED=true

# Dev local : token HA pour le backend (test admin + alertes après scrape)
# HOME_ASSISTANT_TOKEN=your-long-lived-access-token
# NOTIFICATIONS_ENABLED=true
# NOTIFY_SERVICE=persistent_notification.create
# NOTIFY_SERVICE=notify.mobile_app_iphone,notify.mobile_app_pixel
# NOTIFICATIONS_MAX=5
# Alternative front uniquement : web/.env.local avec VITE_HA_TOKEN (le test admin réutilise ce jeton)

# CloakBrowser (optionnel — voir https://github.com/CloakHQ/CloakBrowser)
# Laisser headless=true pour le scraping (recommandé). Headed=false ouvre une fenêtre
# Chromium et verrouille le profil entre deux runs.
# CLOAKBROWSER_HEADLESS=true
# CLOAKBROWSER_RESET_PROFILE=true
# CLOAKBROWSER_PROFILE_DIR=./data/cloakbrowser-profile
# CLOAKBROWSER_HUMANIZE=true
# CLOAKBROWSER_FINGERPRINT=12345
# CLOAKBROWSER_STORAGE_QUOTA=5000
# CLOAKBROWSER_PROXY=http://user:pass@residential-proxy:port
# CLOAKBROWSER_GEOIP=true
